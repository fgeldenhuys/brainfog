{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "architect": {
      "mode": "subagent"
    },
    "implementor": {
      "mode": "subagent"
    },
    "critic": {
      "mode": "subagent"
    },
    "researcher": {
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "fallbacks": ["opencode/deepseek-v4-flash-free", "opencode/mimo-v2.5-free"]
    },
    "planned-implementor": {
      "model": "opencode/big-pickle",
      "fallbacks": ["opencode/deepseek-v4-flash-free", "opencode/mimo-v2.5-free"]
    }
  },
  "mcp": {
    "brainfog": {
      "type": "remote",
      "url": "https://brainfog.francois.online/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:BRAINFOG_BEARER_TOKEN}"
      }
    }
  }
}
